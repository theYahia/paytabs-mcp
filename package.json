    "model-context-protocol",
    "claude",
    "ai",
    "paytabs",
    "uae-api",
    "saudi-api",
    "payments",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/theYahia/paytabs-mcp.git"
  },
  "homepage": "https://github.com/theYahia/paytabs-mcp#readme",
  "author": "theYahia (https://github.com/theYahia)"
