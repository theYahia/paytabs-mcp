{
  "name": "@theyahia/paytabs-mcp",
  "version": "1.1.0",
  "description": "MCP server for PayTabs payment gateway (MENA region)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "paytabs-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
